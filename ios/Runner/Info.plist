<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

	<!-- ================= BASIC APP INFO ================= -->

	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>

	<key>CFBundleDisplayName</key>
	<string>Docmobi</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>CFBundleName</key>
	<string>docmobi</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>

	<key>CFBundleSignature</key>
	<string>????</string>

	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- ================= UI SETTINGS ================= -->

	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- ================= CALL PERMISSIONS (PRIMARY) ================= -->

	<!-- Camera Permission (Video calls) -->
	<key>NSCameraUsageDescription</key>
	<string>Camera access is required for video calls with doctors and recording medical content.</string>

	<!-- Microphone Permission (Audio + Video calls) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Microphone access is required for audio and video calls with healthcare providers.</string>

	<!-- ================= MEDIA PERMISSIONS ================= -->

	<!-- Photo Library Access (Select videos/images) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>We need access to your photo library to select and upload medical reels</string>
	
	<!-- Photo Library Add Only (iOS 14+) -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>We need access to save videos to your photo library</string>
	
	<!-- Camera Access (Video record korar jonno) -->
	<key>NSCameraUsageDescription</key>
	<string>We need access to your camera to record and upload medical reels</string>
	
	<!-- Microphone Access (Video er audio record korar jonno) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>We need access to your microphone to record audio for videos</string>
	
	<!-- Motion Usage (Optional - video recording er shomoy) -->
	<key>NSMotionUsageDescription</key>
	<string>We use motion data to enhance video recording quality</string>
	
	<!-- Local Network (Development er jonno - localhost API) -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>We need access to local network for API communication during development</string>
	
	<!-- App Transport Security Settings (HTTP API calls er jonno) -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Allow all HTTP connections (Development only) -->
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		
		<!-- Production e use korben (specific domain er jonno) -->
		<!--
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		
		<!-- ✅ Exception for your production backend (HTTPS) -->
		<key>NSExceptionDomains</key>
		<dict>
			<key>your-api-domain.com</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<!-- ✅ Your backend uses HTTPS, no need for HTTP exception -->
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<false/>
			</dict>
			
			<!-- ✅ For local development only (uncomment when testing locally) -->
			<!--
			<key>localhost</key>
			<dict>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
			-->
		</dict>
	</dict>
	
	<!-- Background Modes (Optional - video upload continue korar jonno) -->
	<key>UIBackgroundModes</key>
	<array>
		<!-- ✅ Audio - Keep audio running in background during calls -->
		<string>audio</string>
		<!-- ✅ VoIP - For incoming call support -->
		<string>voip</string>
		<!-- ✅ Background fetch -->
		<string>fetch</string>
		<!-- ✅ Remote notifications -->
		<string>remote-notification</string>
		<string>audio</string>
		<string>voip</string>
	</array>
	
</dict>
</plist>